ll.execute_reply":"2026-06-30T10:34:08.715646Z"}},"outputs":[{"name":"stdout","text":"Loading VLM judge: Qwen/Qwen2-VL-2B-Instruct (first run downloads ~5 GB) ...\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Downloading (incomplete total...): 0.00B [00:00, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"d58e297a80c34dafb44b2ca9b7bf6689"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"Fetching 2 files:   0%|          | 0/2 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"375fbd5d42b045fdb2694e4c4a84df46"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"Loading weights:   0%|          | 0/729 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"3e6ce7b9fc234dd284d09dc636c6ab84"}},"metadata":{}},{"name":"stdout","text":"VLM judge loaded. Yes ids=[7414, 9454, 9693, 9834, 14004] No ids=[902, 2152, 2308, 2753, 8996]\n","output_type":"stream"}],"execution_count":20},{"id":"c4a8919b-a22b-4598-8cc1-bc78f7444f47","cell_type":"markdown","source":"## Shared metric functions  ·  *VLM judge · CLIP diversity · difference-of-means CAV (avg+max)*","metadata":{}},{"id":"89f44245-ee5f-4806-8979-35474a81b54d","cell_type":"code","source":"# ─── Image listing + backbone activations (avg + max pooling per layer) ───────\nclass ImageDirDataset(Dataset):\n    def __init__(self, root_dirs, transform=None, max_images=None):\n        if isinstance(root_dirs, (str, os.PathLike)):\n            root_dirs = [root_dirs]\n        self.transform = transform\n        paths = []\n        for root in root_dirs:\n            if not os.path.isdir(root):\n                continue\n            for dp, _, fns in os.walk(root):\n                for fn in fns:\n                    if fn.endswith(IMG_EXTS):\n                        paths.append(os.path.join(dp, fn))\n        paths.sort()\n        if max_images is not None and len(paths) > max_images:\n            idx = np.linspace(0, len(paths) - 1, max_images).astype(int)\n            paths = [paths[i] for i in idx]            # deterministic spread subsample\n        self.paths = paths\n\n    def __len__(self): return len(self.paths)\n\n    def __getitem__(self, idx):\n        img = Image.open(self.paths[idx]).convert('RGB')\n        return self.transform(img) if self.transform else img\n\n\ndef list_image_paths(image_dir, max_n=None):\n    return ImageDirDataset(image_dir, transform=None, max_images=max_n).paths\n\n\n# Per-backbone handles, switched by set_backbone()\nmodel = None\nstandard_transform = None\nACT_CACHE: Dict[Tuple[str, str], Dict[str, Dict[str, np.ndarray]]] = {}\n\n\ndef set_backbone(backbone: str):\n    global model, standard_transform\n    if model is not None:\n        del model\n        if torch.cuda.is_available():\n            torch.cuda.empty_cache()\n    preset = MODEL_REGISTRY[backbone]\n    model = preset['loader']().to(DEVICE)\n    modules = dict(model.named_modules())\n    for ln in preset['target_layers']:\n        if ln not in modules:\n            raise ValueError(f\"Layer '{ln}' not in {backbone}\")\n    cfg.primary_backbone = backbone\n    standard_transform = build_transform(preset['img_size'])\n    ACT_CACHE.clear()\n    print(f'Backbone ready: {backbone} (img_size={preset[\"img_size\"]})')\n\n\ndef _pool4d(out, p):\n    return out.mean(dim=(2, 3)) if p == 'avg' else out.amax(dim=(2, 3))\n\n\ndef extract_activations_byp(image_source, layers, poolings, max_images=None):\n    \"\"\"{layer: {pooling: (N, C)}} in one forward pass per batch.\"\"\"\n    ds = ImageDirDataset(image_source, transform=standard_transform, max_images=max_images)\n    if len(ds) == 0:\n        raise ValueError(f'No images in {image_source}')\n    loader = DataLoader(ds, batch_size=cfg.batch_size, shuffle=False,\n                        num_workers=2, pin_memory=True)\n    modules = dict(model.named_modules())\n    buf = {l: {p: [] for p in poolings} for l in layers}\n    handles = []\n\n    def make_hook(name):\n        def hook(_, __, out):\n            o = out[0] if isinstance(out, tuple) else out\n            for p in poolings:\n                buf[name][p].append((_pool4d(o, p) if o.ndim == 4 else o).detach().cpu())\n        return hook\n\n    for l in layers:\n        handles.append(modules[l].register_forward_hook(make_hook(l)))\n    with torch.no_grad():\n        for batch in loader:\n            model(batch.to(DEVICE, non_blocking=True))\n    for h in handles:\n        h.remove()\n    return {l: {p: torch.cat(v, 0).numpy() for p, v in d.items()} for l, d in buf.items()}\n\n\ndef get_acts_byp(image_source, layers, poolings, max_images=None):\n    key = (str(image_source), cfg.primary_backbone)\n    if key not in ACT_CACHE:\n        ACT_CACHE[key] = extract_activations_byp(image_source, layers, poolings, max_images)\n    return ACT_CACHE[key]\n\n\nset_backbone(cfg.primary_backbone)\nprint('Activation utilities ready.')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-30T10:34:11.835068Z","iopub.execute_input":"2026-06-30T10:34:11.835844Z","iopub.status.idle":"2026-06-30T10:34:12.244178Z","shell.execute_reply.started":"2026-06-30T10:34:11.835814Z","shell.execute_reply":"2026-06-30T10:34:12.2435Z"}},"outputs":[{"name":"stdout","text":"Backbone ready: resnet50 (img_size=224)\nActivation utilities ready.\n","output_type":"stream"}],"execution_count":21},{"id":"66d88bbc-e656-497d-b06a-275fe5e2e89f","cell_type":"code","source":"# ─── VLM-as-judge (logit-based P(yes)) — exp 1.1 ──────────────────────────────\nJUDGE_PROMPT_TMPL = (\n    \"Look at this image. Is '{concept}' the dominant visible pattern?\\n\"\n    \"Answer 'yes' only if the conditions hold; otherwise answer 'no'.\")\n\n\n@torch.inference_mode()\ndef vlm_judge_prob(img_path, concept) -> float:\n    try:\n        img = Image.open(img_path).convert('RGB')\n    except Exception:\n        return float('nan')\n    messages = [{'role': 'user', 'content': [\n        {'type': 'image', 'image': img},\n        {'type': 'text', 'text': JUDGE_PROMPT_TMPL.format(concept=concept)}]}]\n    text = vlm_processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)\n    inputs = vlm_processor(text=[text], images=[img], padding=True,\n                           return_tensors='pt').to(vlm_model.device)\n    last = vlm_model(**inputs).logits[0, -1, :]\n    yes = torch.logsumexp(last[YES_TOKEN_IDS], 0)\n    no  = torch.logsumexp(last[NO_TOKEN_IDS], 0)\n    return float(torch.softmax(torch.stack([yes, no]), 0)[0].item())\n\n\ndef vlm_judge_probs(img_paths, concept):\n    from tqdm.auto import tqdm\n    return [vlm_judge_prob(p, concept)\n            for p in tqdm(img_paths, desc=f\"VLM '{concept}'\", leave=False)]\n\n\ndef compute_vlm_metrics(probs) -> dict:\n    arr = np.array(probs, dtype=np.float32); arr = arr[~np.isnan(arr)]\n    n = int(arr.size); nan = float('nan')\n    if n == 0:\n        return {'N': 0, 'vlm_align_mean': nan, 'vlm_align_std': nan,\n                'vlm_align_pct_below': nan, 'vlm_prec_05': nan, 'vlm_prec_07': nan,\n                'probs': []}\n    return {'N': n,\n            'vlm_align_mean': float(arr.mean()),\n            'vlm_align_std': float(arr.std(ddof=1)) if n > 1 else nan,\n            'vlm_align_pct_below': float((arr < cfg.threshold_alignment).mean() * 100),\n            'vlm_prec_05': float((arr >= 0.5).mean() * 100),\n            'vlm_prec_07': float((arr >= 0.7).mean() * 100),\n            'probs': arr.tolist()}","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-30T10:34:15.887392Z","iopub.execute_input":"2026-06-30T10:34:15.888184Z","iopub.status.idle":"2026-06-30T10:34:15.898181Z","shell.execute_reply.started":"2026-06-30T10:34:15.888153Z","shell.execute_reply":"2026-06-30T10:34:15.897353Z"}},"outputs":[],"execution_count":22},{"id":"871451c6-8c39-4381-9558-345425e8ef5e","cell_type":"code","source":"# ─── CLIP embedding-space metrics: repetition rate, near-dup pairs, PR — exp 1.1\n@torch.no_grad()\ndef embed_images(img_paths, batch_size=64):\n    embs = []\n    for i in range(0, len(img_paths), batch_size):\n        batch_t = []\n        for p in img_paths[i:i + batch_size]:\n            try:\n                batch_t.append(clip_preprocess(Image.open(p).convert('RGB')))\n            except Exception:\n                continue\n        if not batch_t:\n            continue\n        feats = clip_model.encode_image(torch.stack(batch_t).to(DEVICE))\n        feats = feats / feats.norm(dim=-1, keepdim=True)\n        embs.append(feats.cpu().float().numpy())\n    if not embs:\n        return np.zeros((0, CLIP_DIM), dtype=np.float32)\n    return np.vstack(embs).astype(np.float32)\n\n\ndef repdup_from_embs(embs, tau=None):\n    tau = cfg.threshold_repetition if tau is None else tau\n    N = embs.shape[0]\n    if N < 2:\n        return float('nan'), 0\n    sims = (embs @ embs.T)[np.triu_indices(N, 1)]\n    n_high = int((sims > tau).sum())\n    return n_high / sims.size * 100.0, n_high\n\n\ndef participation_ratio_from_embs(embs):\n    N = embs.shape[0]\n    if N < 2:\n        return float('nan')\n    Z = embs - embs.mean(0, keepdims=True)\n    eig = np.linalg.eigvalsh((Z.T @ Z) / (N - 1))\n    eig = eig[eig > 0]\n    return float(eig.sum() ** 2 / (eig ** 2).sum())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-30T10:34:18.195554Z","iopub.execute_input":"2026-06-30T10:34:18.196362Z","iopub.status.idle":"2026-06-30T10:34:18.204715Z","shell.execute_reply.started":"2026-06-30T10:34:18.19633Z","shell.execute_reply":"2026-06-30T10:34:18.20387Z"}},"outputs":[],"execution_count":23},{"id":"a993e58c-1ab8-4730-9a5a-defe0cec3955","cell_type":"code","source":"# ─── difference-of-means CAV in standardized space + multi-pool cosine — exp 2.1\ndef train_cav_std(pos, neg, scaler):\n    Xp, Xn = scaler.transform(pos), scaler.transform(neg)\n    w = Xp.mean(0) - Xn.mean(0)\n    return (w / (np.linalg.norm(w) + 1e-12)).astype(np.float32)\n\n\ndef cos_sim(a, b):\n    return float(1.0 - cosine_dist(a, b))\n\n\ndef build_scalers(neg_byp, layers, poolings):\n    return {l: {p: StandardScaler().fit(neg_byp[l][p]) for p in poolings} for l in layers}\n\n\ndef cav_cosine_per_layer(auto_byp, ref_byp, neg_byp, scalers, layers, poolings):\n    \"\"\"Mean cosine across poolings, per layer: cos(CAV_auto, CAV_ref).\"\"\"\n    out = {}\n    for l in layers:\n        per_pool = []\n        for p in poolings:\n            sc = scalers[l][p]\n            a = train_cav_std(auto_byp[l][p], neg_byp[l][p], sc)\n            r = train_cav_std(ref_byp[l][p], neg_byp[l][p], sc)\n            per_pool.append(cos_sim(a, r))\n        out[l] = float(np.mean(per_pool))\n    return out\n\n\nprint('Metric functions ready.')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-30T10:34:20.527087Z","iopub.execute_input":"2026-06-30T10:34:20.527657Z","iopub.status.idle":"2026-06-30T10:34:20.535042Z","shell.execute_reply.started":"2026-06-30T10:34:20.527626Z","shell.execute_reply":"2026-06-30T10:34:20.534292Z"}},"outputs":[{"name":"stdout","text":"Metric functions ready.\n","output_type":"stream"}],"execution_count":24},{"id":"f7766ef3-2d2e-4a68-ae45-5eb8e3f1efdf","cell_type":"markdown","source":"---\n## §4.3.1 — Starting domain  →  Fig. 18a (per-image judge violin) + Fig. 18b (concept × domain heatmap)\n\nPer-image `P(yes)` is collected for the `single | multi | random` domains (vanilla, sliding_window) and for the reference baseline. The violin shows the per-image distribution by domain; the heatmap shows the per-concept mean alignment. This is the experiment that exposes the **data-scarcity collapse of the random domain** (very few crops, alignment near chance).","metadata":{}},{"id":"ff001cb5-b1db-4858-a3e8-d4ce5bea310b","cell_type":"code","source":"from tqdm.auto import tqdm\n\ndomain_rows = []          # per concept × domain : mean alignment + N\ndomain_probs = {d: [] for d in cfg.domains}   # pooled per-image P(yes) for the violin\nmanual_align = {}         # reference baseline mean alignment per concept\n\nfor concept in tqdm(cfg.concepts, desc='§4.3.1 domains'):\n    # reference baseline\n    man_paths = list_image_paths(resolve_manual_dir(concept), cfg.max_vlm_images)\n    if man_paths:\n        mm = compute_vlm_metrics(vlm_judge_probs(man_paths, concept))\n        manual_align[concept] = mm['vlm_align_mean']\n    # per domain (vanilla, baseline crop)\n    for dom in cfg.domains:\n        pool = resolve_auto_dir(concept, 'vanilla', cfg.baseline_crop, dom)\n        if count_images(pool) == 0:\n            domain_rows.append({'concept': concept, 'domain': dom,\n                                'align_mean': np.nan, 'N': 0})\n            continue\n        paths = list_image_paths(pool, cfg.max_vlm_images)\n        m = compute_vlm_metrics(vlm_judge_probs(paths, concept))\n        domain_rows.append({'concept': concept, 'domain': dom,\n                            'align_mean': m['vlm_align_mean'], 'N': m['N']})\n        domain_probs[dom].extend(m['probs'])\n\ndomain_df = pd.DataFrame(domain_rows)\ndomain_df.to_csv(f'{cfg.output_dir}/domain_alignment.csv', index=False)\nprint(domain_df.pivot(index='concept', columns='domain', values='align_mean').round(3))\nprint('\\nPer-domain N (sum over concepts):',\n      {d: int(domain_df[domain_df.domain == d]['N'].sum()) for d in cfg.domains})","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-30T10:34:23.555691Z","iopub.execute_input":"2026-06-30T10:34:23.556504Z","iopub.status.idle":"2026-06-30T10:39:37.513316Z","shell.execute_reply.started":"2026-06-30T10:34:23.556473Z","shell.execute_reply":"2026-06-30T10:39:37.512459Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"§4.3.1 domains:   0%|          | 0/9 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":