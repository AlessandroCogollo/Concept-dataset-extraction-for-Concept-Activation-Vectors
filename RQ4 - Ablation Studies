euse §4.3.2 negatives/scalers if present, else build\ntry:\n    neg_byp; scalers\nexcept NameError:\n    neg_byp = extract_activations_byp(resolve_negative_dirs(cfg.negative_kind, cfg.baseline_crop),\n                                      LAYERS, CAV_POOLINGS, max_images=cfg.max_negative_pool)\n    scalers = build_scalers(neg_byp, LAYERS, CAV_POOLINGS)\n\n# \"baseline\" = original-prompt extraction (vanilla, sliding_window, multi)\nPROMPT_POOLS = {v: (lambda c, vv=v: resolve_prompt_dir(c, vv)) for v in cfg.prompt_variants}\nPROMPT_POOLS['baseline'] = lambda c: resolve_auto_dir(c, 'vanilla', cfg.baseline_crop, cfg.baseline_split)\nPROMPT_ORDER = cfg.prompt_variants + ['baseline']\n\nintrinsic_rows = []            # per variant × concept (averaged later → Table 3)\ncav_layer_rows = []            # per variant × concept × layer : cosine vs reference\ncav_vectors = {}              # (variant, concept, layer, pool) -> cav  (for pairwise)\n\nfor variant in tqdm(PROMPT_ORDER, desc='§4.3.5 prompts'):\n    for concept in cfg.concepts:\n        pool = PROMPT_POOLS[variant](concept)\n        man = resolve_manual_dir(concept)\n        if count_images(pool) == 0:\n            continue\n        # intrinsic\n        vlm = compute_vlm_metrics(vlm_judge_probs(list_image_paths(pool, cfg.max_vlm_images), concept))\n        embs = embed_images(list_image_paths(pool, cfg.max_auto_images))\n        rep, ndup = repdup_from_embs(embs)\n        pr = participation_ratio_from_embs(embs)\n        intrinsic_rows.append({'variant': variant, 'concept': concept,\n                               'vlm_align_mean': vlm['vlm_align_mean'],\n                               'vlm_align_pct_below': vlm['vlm_align_pct_below'],\n                               'vlm_prec_05': vlm['vlm_prec_05'], 'vlm_prec_07': vlm['vlm_prec_07'],\n                               'rep_rate': rep, 'n_dup_pairs': ndup,\n                               'participation_ratio': pr, 'N': vlm['N']})\n        # CAVs (store per-pool vectors;