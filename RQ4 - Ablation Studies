  torch.cuda.manual_seed_all(GLOBAL_SEED)\n\nDEVICE = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\nprint('Device :', DEVICE)\nprint('PyTorch:', torch.__version__)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-30T10:29:27.896767Z","iopub.execute_input":"2026-06-30T10:29:27.897436Z","iopub.status.idle":"2026-06-30T10:29:42.881889Z","shell.execute_reply.started":"2026-06-30T10:29:27.897393Z","shell.execute_reply":"2026-06-30T10:29:42.881173Z"}},"outputs":[{"name":"stdout","text":"Device : cuda\nPyTorch: 2.10.0+cu128\n","output_type":"stream"}],"execution_count":2},{"id":"4ee796d1-babc-4287-b5f7-84a78d0d5086","cell_type":"code","source":"# ─── Backbone registry (torchvision, ImageNet-1k V1) ──────────────────────────\nIMAGENET_MEAN = [0.485, 0.456, 0.406]\nIMAGENET_STD  = [0.229, 0.224, 0.225]\n\n\ndef _disable_inplace(m: nn.Module) -> nn.Module:\n    for mod in m.modules():\n        if hasattr(mod, 'inplace'):\n            mod.inplace = False\n    return m\n\n\ndef _resnet50_loader():\n    return _disable_inplace(tv_models.resnet50(\n        weights=tv_models.ResNet50_Weights.IMAGENET1K_V1)).eval()\n\n\ndef _vgg16_loader():\n    return _disable_inplace(tv_models.vgg16(\n        weights=tv_models.VGG16_Weights.IMAGENET1K_V1)).eval()\n\n\ndef _inception_v3_loader():\n    m = tv_models.inception_v3(\n        weights=tv_models.Inception_V3_Weights.IMAGENET1K_V1, aux_logits=True)\n    m.aux_logits = False; m.AuxLogits = None\n    return _disable_inplace(m).eval()\n\n\nMODEL_REGISTRY: Dict[str, Dict] = {\n    'resnet50': {\n        'loader': _resnet50_loader, 'img_size': 224,\n        'target_layers': ['layer1.2', 'layer2.3', 'layer3.5', 'layer4.2'],\n        'layer_dims': {'layer1.2': 256, 'layer2.3': 512,\n                       'layer3.5': 1024, 'layer4.2': 2048},\n    },\n    'vgg16': {\n        'loader': _vgg16_loader, 'img_size': 224,\n        'target_layers': ['features.8', 'features.15', 'features.22', 'features.29'],\n        'layer_dims': {'features.8': 128, 'features.15': 256,\n                       'features.22': 512, 'features.29': 512},\n    },\n    'inception_v3': {\n        'loader': _inception_v3_loader, 'img_size': 299,\n        'target_layers': ['Mixed_5d', 'Mixed_6c', 'Mixed_6e', 'Mixed_7c'],\n        'layer_dims': {'Mixed_5d': 288, 'Mixed_6c': 768,\n                       'Mixed_6e': 768, 'Mixed_7c': 2048},\n    },\n}\n\n\ndef build_transform(img_size: int) -> transforms.Compose:\n    return transforms.Compose([\n        transforms.Resize((img_size, img_size)),\n        transforms.ToTensor(),\n        transforms.Normalize(mean=IMAGENET_MEAN, std=IMAGENET_STD),\n    ])\n\n\nprint('Backbone registry ready:', list(MODEL_REGISTRY.keys()))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-30T10:29:42.882871Z","iopub.execute_input":"2026-06-30T10:29:42.883335Z","iopub.status.idle":"2026-06-30T10:29:42.893368Z","shell.execute_reply.started":"2026-06-30T10:29:42.883314Z","shell.execute_reply":"2026-06-30T10:29:42.892507Z"}},"outputs":[{"name":"stdout","text":"Backbone registry ready: ['resnet50', 'vgg16', 'inception_v3']\n","output_type":"stream"}],"execution_count":3},{"id":"173b609b-16bc-4560-8036-93b25ea7ae50","cell_type":"markdown","source":"## Configuration","metadata":{}},{"id":"8f1381d2-4a71-45dd-aa5e-74fa3bba6592","cell_type":"code","source":"@dataclass\nclass Config:\n    # ── Axes ────────────────────────────────────────────────────────\n    concepts: List[str] = field(default_factory=lambda: [\n        'striped', 'dotted', 'chequered', 'wood', 'water',\n        'braided', 'bubbly', 'fibrous', 'veined'])\n    crop_methods: List[str] = field(default_factory=lambda: [\n        'bbox', 'center_mask', 'largest_bbox', 'sliding_window'])\n    auto_sources: List[str] = field(default_factory=lambda: ['vanilla', 'augmented'])\n    domains: List[str] = field(default_factory=lambda: ['single', 'multi', 'random'])\n\n    baseline_crop:  str = 'sliding_window'   # crop policy for §4.3.1 / §4.3.4 / §4.3.5\n    baseline_split: str = 'multi'            # starting domain for the non-domain ablations\n    crop_aug_split: str = 'multi'            # split used in the §4.3.2/§4.3.3 grid\n\n    # ── CAV ─────────────────────────────────────────────────────────\n    cav_poolings: List[str] = field(default_factory=lambda: ['avg', 'max'])\n    negative_kind: str = 'full'              # 'full' | 'cropped'\n\n    # ── Backbones for §4.3.4 ────────────────────────────────────────\n    backbones: List[str] = field(default_factory=lambda: ['resnet50', 'vgg16', 'inception_v3'])\n    primary_backbone: str = 'resnet50'\n\n    # ── Prompt variations for §4.3.5 ────────────────────────────────\n    prompt_variants: List[str] = field(default_factory=lambda: [\n        'bare_term', 'surface_phrase', 'texture_phrase'])\n\n    # ── Sampling caps (the VLM judge is the slow part) ──────────────\n    max_auto_images:   int = 100\n    max_vlm_images:    int = 60\n    max_manual_images: int = 100\n    max_negative_pool: int = 300\n    batch_size:        int = 32\n\n    # ── Metric params ───────────────────────────────────────────────\n    threshold_repetition: float = 0.95\n    threshold_alignment:  float = 0.25\n\n    clip_model_name: str = 'ViT-B-32'\n    clip_pretrained: str = 'openai'\n    vlm_model_id:    str = 'Qwen/Qwen2-VL-2B-Instruct'\n\n    output_dir: str = '/kaggle/working/ablation_output'\n\n\ncfg = Config()\nPath(cfg.output_dir).mkdir(parents=True, exist_ok=True)\nCAV_POOLINGS = cfg.cav_poolings\nprint('Config ready. CAV poolings:', CAV_POOLINGS, '| negatives:', cfg.negative_kind)\nprint('Concepts:', cfg.concepts)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-30T10:29:42.894491Z","iopub.execute_input":"2026-06-30T10:29:42.894804Z","iopub.status.idle":"2026-06-30T10:29:42.927493Z","shell.execute_reply.started":"2026-06-30T10:29:42.894774Z","shell.execute_reply":"2026-06-30T10:29:42.926907Z"}},"outputs":[{"name":"stdout","text":"Config ready. CAV poolings: ['avg', 'max'] | negatives: full\nConcepts: ['striped', 'dotted', 'chequered', 'wood', 'water', 'braided', 'bubbly', 'fibrous', 'veined']\n","output_type":"stream"}],"execution_count":4},{"id":"afffb7d1-0a3b-4230-8479-2f422f3f61c3","cell_type":"markdown","source":"## Dataset layout & path resolution  ·  *matches exp 1.1 / 2.1 and the §4.3.2 ablation*\n\nRobust to the different Kaggle mounts seen across the deliverables. Each resolver returns the first existing, non-empty candidate and the availability probe prints what was found, so wrong slugs surface immediately.","metadata":{}},{"id":"c93fc909-1c3e-400b-b862-1f7cbed9194d","cell_type":"code","source":"def _resolve_root(*candidates: str) -> str:\n    for c in candidates:\n        if Path(c).exists():\n            return c\n    return candidates[0]\n\n\n# Roots (extend the candidate lists if your mounts differ)\nACG_ROOT = _resolve_root(\n    '/kaggle/input/datasets/alessandrocogollo/acg4cav-base-extraction/dataset',\n    '/kaggle/input/datasets/alessandrocogollo/acg4cav-extracted-concepts/crops',\n    '/kaggle/input/acg4cav-extracted-concepts/crops')\nVTCAV_ROOT = _resolve_root(\n    '/kaggle/input/datasets/alessandrocogollo/vtcav-dataset',\n    '/kaggle/input/vtcav-dataset')\nDTD_CONCEPT_ROOT = f'{VTCAV_ROOT}/DTD-Concept'\nDTD2_ROOT = _resolve_root(\n    '/kaggle/input/datasets/jmexpert/describable-textures-dataset-dtd/dtd/images',\n    '/kaggle/input/describable-textures-dataset-dtd/dtd/images')\nT2I_ROOT = _resolve_root(\n    '/kaggle/input/datasets/alessandrocogollo/zeroshot-t2i-concepts/concepts',\n    '/kaggle/input/zeroshot-t2i-concepts/concepts')\n\nPIPELINE_ALIASES = {'vanilla': ['vanilla'], 'augmented': ['augmented', 'augmentation']}\n\n# Reference (so-called \"manual\") baselines. NOTE: wood/water/bubbly use the\n# synthetic T2I set, not DTD — see T2I_CONCEPTS below for correct labelling.\nMANUAL_CANDIDATES: Dict[str, List[str]] = {\n    'striped':   [f'{DTD2_ROOT}/striped',   f'{DTD_CONCEPT_ROOT}/striped'],\n    'dotted':    [f'{DTD2_ROOT}/dotted',    f'{DTD_CONCEPT_ROOT}/dotted'],\n    'chequered': [f'{DTD2_ROOT}/chequered', f'{DTD_CONCEPT_ROOT}/chequered'],\n    'wood':      [f'{T2I_ROOT}/wood/wood'],\n    'water':     [f'{T2I_ROOT}/water/water'],\n    'braided':   [f'{DTD2_ROOT}/braided',   f'{DTD_CONCEPT_ROOT}/braided'],\n    'bubbly':    [f'{T2I_ROOT}/bubbly/bubbly'],\n    'fibrous':   [f'{DTD2_ROOT}/fibrous',   f'{DTD_CONCEPT_ROOT}/fibrous'],\n    'veined':    [f'{DTD2_ROOT}/veined',    f'{DTD_CONCEPT_ROOT}/veined'],\n}\nT2I_CONCEPTS = {'wood', 'water', 'bubbly'}   # reference = synthetic (label accordingly)\n\nIMG_EXTS = ('.jpg', '.jpeg', '.png', '.bmp', '.webp', '.tif', '.tiff', '.JPEG', '.JPG', '.PNG')\n\n\ndef count_images(d) -> int:\n    if isinstance(d, (list, tuple)):\n        return sum(count_images(x) for x in d)\n    if not Path(d).exists():\n        return 0\n    n = 0\n    for _, _, fns in os.walk(d):\n        n += sum(fn.endswith(IMG_EXTS) for fn in fns)\n    return n\n\n\ndef _auto_dir(concept, alias, crop, split):\n    return f'{ACG_ROOT}/{alias}/{alias}_{crop}/{concept}/{split}'\n\n\ndef resolve_auto_dir(concept, source, crop, split) -> str:\n    cands = [_auto_dir(concept, a, crop, split) for a in PIPELINE_ALIASES[source]]\n    for c in cands:\n        if Path(c).is_dir() and count_images(c) > 0:\n            return c\n    return cands[0]\n\n\ndef resolve_manual_dir(concept) -> str:\n    for c in MANUAL_CANDIDATES[concept]:\n        if Path(c).is_dir() and count_images(c) > 0:\n            return c\n    return MANUAL_CANDIDATES[concept][0]\n\n\n# ── Prompt-variation pools (§4.3.5): multi-class, vanilla, sliding_window ──────\n# Folder names vary between dataset versions; the resolver tries several layouts.\ndef resolve_prompt_dir(concept, variant, split=None, crop=None) -> str:\n    split = split or cfg.baseline_split\n    crop  = crop or cfg.baseline_crop\n    cands = [\n        f'/kaggle/input/datasets